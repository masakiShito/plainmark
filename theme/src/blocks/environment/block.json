{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "plainmark/environment",
	"version": "0.1.0",
	"title": "Environment",
	"category": "text",
	"icon": "desktop",
	"description": "Display environment information in a formatted block.",
	"keywords": ["environment", "system", "info", "specs"],
	"textdomain": "plainmark",
	"attributes": {
		"title": {
			"type": "string",
			"default": ""
		},
		"items": {
			"type": "array",
			"default": [],
			"items": {
				"type": "object",
				"properties": {
					"label": {
						"type": "string"
					},
					"value": {
						"type": "string"
					}
				}
			}
		}
	},
	"supports": {
		"html": false,
		"anchor": true
	},
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"render": "file:./render.php"
}
