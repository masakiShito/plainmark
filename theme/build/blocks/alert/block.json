{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "plainmark/alert",
  "version": "0.1.0",
  "title": "Alert",
  "category": "text",
  "icon": "warning",
  "description": "Display an alert block with different types (note, info, tip, warning, danger).",
  "keywords": [
    "alert",
    "note",
    "info",
    "tip",
    "warning",
    "danger",
    "callout"
  ],
  "textdomain": "plainmark",
  "attributes": {
    "type": {
      "type": "string",
      "default": "note",
      "enum": [
        "note",
        "info",
        "tip",
        "warning",
        "danger"
      ]
    },
    "title": {
      "type": "string",
      "default": ""
    },
    "content": {
      "type": "string",
      "default": ""
    }
  },
  "supports": {
    "html": false,
    "anchor": true
  },
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "render": "file:./render.php"
}